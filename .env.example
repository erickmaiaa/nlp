# Copy to ".env" and adjust as needed. All variables are optional;
# sensible defaults are applied in src/nlp_toolkit/config.py.

# Override data / output locations (absolute or relative to the repo root).
NLP_DATA_DIR=notebooks/data
NLP_OUTPUT_DIR=outputs

# Reproducibility and model selection.
NLP_RANDOM_SEED=42
NLP_LANGUAGE=english
NLP_SPACY_MODEL=en_core_web_sm
NLP_ENCODING=utf-8
NLP_TOP_N=5
